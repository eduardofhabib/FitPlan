<% content_for(:title, t('.title')) %>

<div class="mb-4 d-flex justify-content-between">
  <h1>
    <% unless request.referer.to_s.include?("/social/profiles") %>
      <%= t('.title') %>
    <% else %>
      <%= link_to request.referer, class: 'd-flex align-items-center gap-2 text-decoration-none text-body' do %>
        <i class="bi bi-arrow-left-short"></i><%= t('.title') %>
      <% end %>
    <% end %>
  </h1>
  
  <%= button_to "Log out", Current.session, method: :delete, data: { controller: "bridge--nav-button", bridge_title: "Log out", 'turbo-confirm': t('message_destroy') }, class: 'btn btn-danger hide-on-mobile' %>
</div>

<div class="d-flex flex-column" style="min-height: calc(100vh - 160px);">
  <div>
    <div class="mb-3 text-center">
      <div class="d-flex justify-content-center align-items-center mb-3 gap-4">
        <div class="position-relative">
          <% if Current.user.unseen_followers? %>
            <span class="position-absolute top-0 start-100 translate-middle p-1 bg-warning rounded-circle"></span>
          <% end %>

          <%= link_to t('social.profiles.show.followers', count: Current.user.followers.count), followers_social_profile_path(Current.user), class: 'text-primary text-decoration-none fw-semibold' %>
        </div>

        <%= link_to t('social.profiles.show.followings', count: Current.user.followings.count), followings_social_profile_path(Current.user), class: 'text-primary text-decoration-none fw-semibold' %>
      </div>

      <%= render "avatar_form", user: @user %>

      <h5 class="mb-2 fw-bold"><%= @user.name %></h5>

      <p class="mb-2 text-muted"><i class="bi bi-person-fill"></i> @<%= @user.handle %></p>
      <p class="text-muted small"><i class="bi bi-envelope-fill"></i> <%= @user.email %></p>
    </div>

    <div class="d-flex justify-content-start align-items-center gap-2 mt-2">
      <div class="dropdown">
        <button class="btn btn-sm btn-light border dropdown-toggle" type="button" data-bs-toggle="dropdown">
          <i class="bi bi-person-fill me-1"></i><%= t('.profile') %>
        </button>
        <ul class="dropdown-menu">
          <li>
            <%= link_to edit_identity_profile_path, class: "dropdown-item" do %>
              <i class="bi bi-pencil-square me-2"></i><%= t('.edit') %>
            <% end %>
          </li>
          <li>
            <%= link_to @user.healthy_metric.present? ? identity_healthy_metric_path : new_identity_healthy_metric_path, class: "dropdown-item" do %>
              <i class="bi bi-calculator-fill me-2"></i><%= t('.metrics') %>
            <% end %>
          </li>
          <li>
            <%= link_to dashboard_path, class: "dropdown-item" do %>
              <i class="bi bi-activity me-2"></i><%= t('link_dashboard') %>
            <% end %>
          </li>
        </ul>
      </div>

      <%= link_to identity_settings_path, class: "btn btn-sm btn-light border" do %>
        <i class="bi bi-gear-fill me-1"></i><%= t('identity.settings.show.title') %>
      <% end %>
    </div>
  </div>

  <%= image_tag 'undraw/profile.svg', alt: '', class: 'img-fluid mt-auto ms-auto', style: 'width: 25rem;' %>
</div>
